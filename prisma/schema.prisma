generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model HealthCheck {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique
  label String
  group String
  roles Role[] @relation("RolePermissions")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  isSystem    Boolean      @default(false)
  permissions Permission[] @relation("RolePermissions")
  users       User[]
  invitations Invitation[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  firstName        String
  lastName         String
  phone            String?
  avatarUrl        String?
  passwordHash     String?
  totpSecret       String?
  totpEnabled      Boolean          @default(false)
  totpBackupCodes  String[]
  locale           String           @default("en")
  status           UserStatus       @default(INVITED)
  roleId           String
  role             Role             @relation(fields: [roleId], references: [id])
  assignedClients          Client[]
  invitations              Invitation[]
  assignedTickets          Ticket[]         @relation("TicketAssignee")
  createdTickets           Ticket[]         @relation("TicketCreatedBy")
  ticketComments           TicketComment[]  @relation("TicketCommentAuthor")
  ticketActivities         TicketActivity[] @relation("TicketActivityActor")
  ledProjects              Project[]        @relation("ProjectLead")
  assignedTasks            ProjectTask[]    @relation("ProjectTaskAssignee")
  assignedVisits           Visit[]          @relation("VisitAssignee")
  assignedRecurringVisits  RecurringVisit[] @relation("RecurringVisitAssignee")
  timeEntries              TimeEntry[]      @relation("TimeEntryUser")
  approvedTimeEntries      TimeEntry[]      @relation("TimeEntryApprover")
  timeTimer                TimeTimer?       @relation("TimeTimerUser")
  passwordResets           PasswordResetToken[]
  knowledgeArticles        KnowledgeArticle[] @relation("KnowledgeAuthor")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

model Client {
  id                   String       @id @default(cuid())
  companyName          String
  domain               String?
  contactName          String?
  contactEmail         String?
  contactPhone         String?
  address              String?
  city                 String?
  postalCode           String?
  country              String?
  notes                String?
  industryId           String?
  industry             ClientIndustry? @relation(fields: [industryId], references: [id])
  status               ClientStatus @default(ACTIVE)
  assignedTechnicianId String?
  assignedTechnician   User?        @relation(fields: [assignedTechnicianId], references: [id])
  tickets              Ticket[]
  contacts             ClientContact[]
  projects             Project[]
  visits               Visit[]
  recurringVisits      RecurringVisit[]
  timeEntries          TimeEntry[]
  timeTimers           TimeTimer[]
  contracts            Contract[]
  devices              Device[]
  subscriptions        Subscription[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Invitation {
  id        String           @id @default(cuid())
  email     String
  roleId    String
  role      Role             @relation(fields: [roleId], references: [id])
  tokenHash String           @unique
  expiresAt DateTime
  status    InvitationStatus @default(PENDING)
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model AppSetting {
  id              String   @id @default("singleton")
  companyName     String   @default("OpsCenter")
  logoData        Bytes?
  logoMimeType    String?
  smtpHost        String?
  smtpPort        Int?
  smtpUser        String?
  smtpPasswordEnc String?
  smtpFrom        String?
  smtpSecure      Boolean  @default(false)
  timesheetingEnabled Boolean @default(false)
  defaultHourlyRateCents Int?
  contractsEnabled    Boolean @default(false)
  devicesEnabled      Boolean @default(false)
  enforce2fa          Boolean @default(false)
  defaultLocale       String  @default("en")
  subscriptionsEnabled Boolean @default(false)
  updatedAt       DateTime @updatedAt
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING
  RESOLVED
  CLOSED
}

enum TicketActivityType {
  CREATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  UNASSIGNED
  COMMENTED
}

model Ticket {
  id          String           @id @default(cuid())
  number      Int              @unique @default(autoincrement())
  subject     String
  description String
  status      TicketStatus     @default(OPEN)
  categoryId  String
  category    TicketCategory   @relation(fields: [categoryId], references: [id])
  priorityId  String
  priority    TicketPriority   @relation(fields: [priorityId], references: [id])
  clientId    String
  client      Client           @relation(fields: [clientId], references: [id])
  assigneeId  String?
  assignee    User?            @relation("TicketAssignee", fields: [assigneeId], references: [id])
  createdById String?
  createdBy   User?            @relation("TicketCreatedBy", fields: [createdById], references: [id])
  createdByContactId String?
  createdByContact   ClientContact? @relation("TicketCreatedByContact", fields: [createdByContactId], references: [id], onDelete: SetNull)
  comments    TicketComment[]
  activities  TicketActivity[]
  timeEntries TimeEntry[]
  timeTimers  TimeTimer[]
  tags        TicketTag[]
  deviceId    String?
  device      Device?          @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  dueAt       DateTime?
  closedAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model TicketTag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation("TicketCommentAuthor", fields: [authorId], references: [id])
  authorContactId String?
  authorContact   ClientContact? @relation("TicketCommentAuthorContact", fields: [authorContactId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime @default(now())
}

model TicketActivity {
  id        String             @id @default(cuid())
  ticketId  String
  ticket    Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?              @relation("TicketActivityActor", fields: [actorId], references: [id])
  type      TicketActivityType
  fromValue String?
  toValue   String?
  createdAt DateTime           @default(now())
}

model TicketCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketPriority {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientContact {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String
  jobTitle      String?
  email         String?
  phone         String?
  isVip         Boolean  @default(false)
  photoData     Bytes?
  photoMimeType String?
  portalEnabled Boolean  @default(false)
  portalCanCreate  Boolean @default(true)
  portalCanComment Boolean @default(true)
  locale        String   @default("en")
  passwordHash  String?
  portalTokens  PortalToken[]
  createdTickets  Ticket[]        @relation("TicketCreatedByContact")
  ticketComments  TicketComment[] @relation("TicketCommentAuthorContact")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PortalToken {
  id        String    @id @default(cuid())
  contactId String
  contact   ClientContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model ClientIndustry {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  clients   Client[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model ProjectStatus {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String    @default("#6b7280")
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ProjectTaskStatus {
  id        String        @id @default(cuid())
  name      String        @unique
  color     String        @default("#6b7280")
  sortOrder Int           @default(0)
  isActive  Boolean       @default(true)
  tasks     ProjectTask[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  number      Int           @unique @default(autoincrement())
  name        String
  description String?
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id])
  statusId    String
  status      ProjectStatus @relation(fields: [statusId], references: [id])
  leadId      String?
  lead        User?         @relation("ProjectLead", fields: [leadId], references: [id])
  startDate   DateTime?
  dueDate     DateTime?
  tasks       ProjectTask[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ProjectTask {
  id          String            @id @default(cuid())
  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  statusId    String
  status      ProjectTaskStatus @relation(fields: [statusId], references: [id])
  assigneeId  String?
  assignee    User?             @relation("ProjectTaskAssignee", fields: [assigneeId], references: [id])
  priority    TaskPriority      @default(MEDIUM)
  startDate   DateTime?
  dueDate     DateTime?
  sortOrder   Int               @default(0)
  timeEntries TimeEntry[]
  timeTimers  TimeTimer[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum VisitStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model VisitType {
  id              String           @id @default(cuid())
  name            String           @unique
  color           String           @default("#6b7280")
  sortOrder       Int              @default(0)
  isActive        Boolean          @default(true)
  visits          Visit[]
  recurringVisits RecurringVisit[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model RecurringVisit {
  id              String              @id @default(cuid())
  title           String
  description     String?
  typeId          String
  type            VisitType           @relation(fields: [typeId], references: [id])
  clientId        String?
  client          Client?             @relation(fields: [clientId], references: [id])
  assigneeId      String?
  assignee        User?               @relation("RecurringVisitAssignee", fields: [assigneeId], references: [id])
  location        String?
  durationMinutes Int                 @default(60)
  frequency       RecurrenceFrequency
  interval        Int                 @default(1)
  weekdays        Int[]
  startDate       DateTime
  endDate         DateTime?
  timeHour        Int                 @default(9)
  timeMinute      Int                 @default(0)
  isActive        Boolean             @default(true)
  visits          Visit[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model Visit {
  id               String          @id @default(cuid())
  title            String
  description      String?
  typeId           String
  type             VisitType       @relation(fields: [typeId], references: [id])
  clientId         String?
  client           Client?         @relation(fields: [clientId], references: [id])
  assigneeId       String?
  assignee         User?           @relation("VisitAssignee", fields: [assigneeId], references: [id])
  location         String?
  scheduledAt      DateTime
  durationMinutes  Int             @default(60)
  status           VisitStatus     @default(SCHEDULED)
  notes            String?
  recurringVisitId String?
  recurringVisit   RecurringVisit? @relation(fields: [recurringVisitId], references: [id], onDelete: SetNull)
  timeEntries      TimeEntry[]
  timeTimers       TimeTimer[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model TimeEntry {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation("TimeEntryUser", fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime
  minutes         Int
  description     String?
  billable        Boolean         @default(true)
  hourlyRateCents Int?
  status          TimeEntryStatus @default(DRAFT)
  ticketId        String?
  ticket          Ticket?         @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  taskId          String?
  task            ProjectTask?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  visitId         String?
  visit           Visit?          @relation(fields: [visitId], references: [id], onDelete: SetNull)
  clientId        String?
  client          Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  approvedById    String?
  approvedBy      User?           @relation("TimeEntryApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId, date])
  @@index([status])
}

model TimeTimer {
  id          String       @id @default(cuid())
  userId      String       @unique
  user        User         @relation("TimeTimerUser", fields: [userId], references: [id], onDelete: Cascade)
  description String?
  ticketId    String?
  ticket      Ticket?      @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  taskId      String?
  task        ProjectTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  visitId     String?
  visit       Visit?       @relation(fields: [visitId], references: [id], onDelete: SetNull)
  clientId    String?
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  startedAt   DateTime     @default(now())
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_OFF
}

model ContractType {
  id                     String     @id @default(cuid())
  name                   String     @unique
  color                  String     @default("#6b7280")
  sortOrder              Int        @default(0)
  isActive               Boolean    @default(true)
  defaultHourlyRateCents Int?
  contracts              Contract[]
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
}

model ContractStatus {
  id        String     @id @default(cuid())
  name      String     @unique
  color     String     @default("#6b7280")
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  contracts Contract[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Contract {
  id                      String         @id @default(cuid())
  number                  Int            @unique @default(autoincrement())
  name                    String?
  clientId                String
  client                  Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  typeId                  String
  type                    ContractType   @relation(fields: [typeId], references: [id])
  statusId                String
  status                  ContractStatus @relation(fields: [statusId], references: [id])
  startDate               DateTime
  endDate                 DateTime?
  valueCents              Int?
  billingCycle            BillingCycle   @default(MONTHLY)
  includedMinutesPerPeriod Int?
  notes                   String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  @@index([clientId])
  @@index([statusId])
}

enum KnowledgeStatus {
  DRAFT
  PUBLISHED
}

model KnowledgeCategory {
  id        String             @id @default(cuid())
  name      String             @unique
  color     String             @default("#6b7280")
  sortOrder Int                @default(0)
  isActive  Boolean            @default(true)
  articles  KnowledgeArticle[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model KnowledgeArticle {
  id         String             @id @default(cuid())
  title      String
  body       String
  excerpt    String?
  status     KnowledgeStatus    @default(DRAFT)
  visibleToPortal Boolean       @default(false)
  categoryId String?
  category   KnowledgeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  authorId   String?
  author     User?              @relation("KnowledgeAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([status])
  @@index([categoryId])
}

model DeviceType {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  devices   Device[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeviceStatus {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6b7280")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  devices   Device[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Device {
  id             String       @id @default(cuid())
  number         Int          @unique @default(autoincrement())
  name           String
  typeId         String
  type           DeviceType   @relation(fields: [typeId], references: [id])
  statusId       String
  status         DeviceStatus @relation(fields: [statusId], references: [id])
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  serialNumber   String?
  manufacturer   String?
  model          String?
  hostname       String?
  purchaseDate   DateTime?
  warrantyExpiry DateTime?
  notes          String?
  tickets        Ticket[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([clientId])
  @@index([statusId])
}

model Subscription {
  id            String             @id @default(cuid())
  number        Int                @unique @default(autoincrement())
  name          String
  typeId        String
  type          SubscriptionType   @relation(fields: [typeId], references: [id])
  statusId      String
  status        SubscriptionStatus @relation(fields: [statusId], references: [id])
  clientId      String?
  client        Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  provider      String?
  reference     String?
  costCents     Int?
  billingCycle  BillingCycle       @default(MONTHLY)
  seats         Int?
  startDate     DateTime?
  renewalDate   DateTime?
  autoRenew     Boolean            @default(true)
  supportLevel  String?
  warrantyEnd   DateTime?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([clientId])
  @@index([statusId])
  @@index([renewalDate])
}

model SubscriptionType {
  id            String         @id @default(cuid())
  name          String
  color         String         @default("#3b82f6")
  sortOrder     Int            @default(0)
  isActive      Boolean        @default(true)
  subscriptions Subscription[]
}

model SubscriptionStatus {
  id            String         @id @default(cuid())
  name          String
  color         String         @default("#3b82f6")
  sortOrder     Int            @default(0)
  isActive      Boolean        @default(true)
  subscriptions Subscription[]
}
